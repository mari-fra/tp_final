\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Arquitectura original del modelo Transformer \cite  {vaswani2017}. El módulo \emph  {encoder} (izquierda) procesa la secuencia de entrada y produce representaciones contextuales; el módulo \emph  {decoder} (derecha) genera la secuencia de salida. Los modelos de clasificación como BERT utilizan únicamente el encoder; los modelos generativos como GPT utilizan únicamente el decoder.}}{11}{figure.caption.3}\protected@file@percent }
\newlabel{fig:transformer-vaswani}{{3}{11}{Arquitectura original del modelo Transformer \cite {vaswani2017}. El módulo \emph {encoder} (izquierda) procesa la secuencia de entrada y produce representaciones contextuales; el módulo \emph {decoder} (derecha) genera la secuencia de salida. Los modelos de clasificación como BERT utilizan únicamente el encoder; los modelos generativos como GPT utilizan únicamente el decoder}{figure.caption.3}{}}
